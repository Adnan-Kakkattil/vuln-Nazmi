# ============================================================================
# TIVORA ELECTRONICS - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control (keep it in .gitignore)
# ============================================================================

# Application Environment
APP_ENV=production
APP_NAME=BLine Boutique
APP_URL=http://localhost
APP_TIMEZONE=Asia/Kolkata

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

DB_CONNECTION=mysql
DB_HOST=srv1336.hstgr.io
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ============================================================================
# SECURITY KEYS
# ============================================================================

APP_KEY=
JWT_SECRET=

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ============================================================================
# PAYMENT GATEWAY - RAZORPAY
# ============================================================================

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_TEST_MODE=true

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@tivoraelectronics.com
MAIL_FROM_NAME=""

# ============================================================================
# CORS CONFIGURATION (for API)
# ============================================================================

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# RATE LIMITING (for API)
# ============================================================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_PER_MINUTES=1

# ============================================================================
# CACHE & LOGGING
# ============================================================================

CACHE_DRIVER=file
LOG_CHANNEL=stack
LOG_LEVEL=error

# ============================================================================
# ADMIN CONFIGURATION
# ============================================================================

ADMIN_PANEL_URL=/admin
ADMIN_SESSION_TIMEOUT=3600

# ============================================================================
# FEATURE FLAGS
# ============================================================================

FEATURE_B2B_ENABLED=true
FEATURE_REVIEWS_ENABLED=true
FEATURE_WISHLIST_ENABLED=true
FEATURE_NOTIFICATIONS_ENABLED=true

# ============================================================================
# DEBUG & DEVELOPMENT
# ============================================================================

DEBUG=false
LOG_SQL_QUERIES=false
SHOW_ERRORS=false
